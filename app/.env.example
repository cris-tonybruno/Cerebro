# ── Cérebro M1 ──────────────────────────────────────────────
# Copie para .env.local e preencha. NUNCA commitar .env.local.

# Anthropic — Claude Principal
ANTHROPIC_API_KEY=

# OpenAI — embeddings (text-embedding-3-small)
OPENAI_API_KEY=

# Supabase — projeto dedicado "cerebro" (Settings → API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE=

# Senha de acesso ao app (única, tela de login)
APP_PASSWORD=

# ElevenLabs — voz das respostas (M2). Sem chave, o app funciona mudo.
# elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=
# Voz (opcional; default = Adam multilíngue). Pegue IDs em elevenlabs.io/voice-library
# ELEVENLABS_VOICE_ID=

# Telegram — corpo provisório (M2.5). Bot criado no @BotFather.
TELEGRAM_BOT_TOKEN=
# Seu chat_id (o bot te fala qual é na primeira mensagem)
TELEGRAM_CHAT_ID=
# Segredo do webhook (string aleatória qualquer; usada no setWebhook)
TELEGRAM_WEBHOOK_SECRET=

# Busca web (M3) — grátis em tavily.com (1000 buscas/mês). Sem chave, a ferramenta avisa.
TAVILY_API_KEY=

# Cost-aware (diretiva, princípio 9)
MONTHLY_BUDGET_CAD=50
USD_TO_CAD=1.37

# Modelos (defaults já são os certos; mude só se quiser)
# CLAUDE_MODEL=claude-opus-4-8
# CLAUDE_MEMORY_MODEL=claude-haiku-4-5
